/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/i2c/i2c.h>

/*
 * Custom PCB board definition — nRF52840 + KXTJ3-1057 accelerometer
 *
 * !! Update pin numbers to match YOUR schematic before building !!
 *
 * Default pin assignments used here:
 *   UART TX  : P0.06
 *   UART RX  : P0.08
 *   I2C SDA  : P0.04   (KXTJ3 SDA)
 *   I2C SCL  : P0.05   (KXTJ3 SCL)
 *   Status LED: P1.10  (active-low)
 */

/ {
	model = "My Custom nRF52840 Board";
	compatible = "my-company,my-custom-board";

	chosen {
		zephyr,console    = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,sram       = &sram0;
		zephyr,flash      = &flash0;
	};

	leds {
		compatible = "gpio-leds";
		led0: led_0 {
			/* Status LED — update pin to match schematic */
			gpios = <&gpio1 10 GPIO_ACTIVE_LOW>;
			label = "Status LED";
		};
	};

	aliases {
		led0 = &led0;
	};
};

&pinctrl {
	uart0_default: uart0_default {
		group1 {
			/* Update TX/RX pins to match schematic */
			psels = <NRF_PSEL(UART_TX, 0, 6)>,
				<NRF_PSEL(UART_RX, 0, 8)>;
		};
	};
	uart0_sleep: uart0_sleep {
		group1 {
			psels = <NRF_PSEL(UART_TX, 0, 6)>,
				<NRF_PSEL(UART_RX, 0, 8)>;
			low-power-enable;
		};
	};

	i2c0_default: i2c0_default {
		group1 {
			/*
			 * Update SDA/SCL pins to match KXTJ3 routing on schematic.
			 * P0.04 = SDA, P0.05 = SCL used here as an example.
			 */
			psels = <NRF_PSEL(TWIM_SDA, 0, 4)>,
				<NRF_PSEL(TWIM_SCL, 0, 5)>;
		};
	};
	i2c0_sleep: i2c0_sleep {
		group1 {
			psels = <NRF_PSEL(TWIM_SDA, 0, 4)>,
				<NRF_PSEL(TWIM_SCL, 0, 5)>;
			low-power-enable;
		};
	};
};

&uart0 {
	status = "okay";
	compatible = "nordic,nrf-uarte";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-1 = <&uart0_sleep>;
	pinctrl-names = "default", "sleep";
};

&i2c0 {
	status = "okay";
	pinctrl-0 = <&i2c0_default>;
	pinctrl-1 = <&i2c0_sleep>;
	pinctrl-names = "default", "sleep";
	clock-frequency = <I2C_BITRATE_FAST>;

	/*
	 * KXTJ3-1057 accelerometer is soldered to this PCB.
	 * Address 0x0E = ADDR pin tied to GND.
	 * Change to <0x0f> if ADDR pin is tied to VDD.
	 */
	kxtj3: kxtj3@e {
		compatible = "i2c-device";
		reg = <0x0e>;
		label = "KXTJ3";
	};
};

&gpio0 { status = "okay"; };
&gpio1 { status = "okay"; };

/* USB — nRF52840 has a built-in USB full-speed controller */
&usbd {
	compatible = "nordic,nrf-usbd";
	status = "okay";
};
